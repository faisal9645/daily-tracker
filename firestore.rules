rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128; 
    }
    
    function isGoogleSignedIn() {
      return isSignedIn()
        && request.auth.token.firebase.sign_in_provider == 'google.com';
    }

    function isOwner(userId) {
      return isGoogleSignedIn() && request.auth.uid == userId;
    }

    // User entity validation
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt'])
        && data.keys().size() <= 5
        && data.userId is string
        && data.userId.size() <= 128
        && data.email is string
        && data.email.size() <= 200
        && data.createdAt is string
        && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 100))
        && (!data.keys().hasAny(['photoURL']) || (data.photoURL is string && data.photoURL.size() <= 500));
    }

    // Task entity validation
    function isValidTask(data) {
      return data.keys().hasAll(['title', 'date', 'completed', 'priority', 'category'])
        && data.keys().size() <= 12
        && data.title is string
        && data.title.size() <= 200
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 1000))
        && data.date is string
        && data.date.size() == 10
        && (!data.keys().hasAny(['time']) || (data.time is string && data.time.size() <= 5))
        && data.completed is bool
        && data.priority is string
        && (data.priority == 'low' || data.priority == 'medium' || data.priority == 'high')
        && data.category is string
        && data.category.size() <= 100
        && (!data.keys().hasAny(['duration']) || (data.duration is number && data.duration >= 0 && data.duration <= 1440))
        && (!data.keys().hasAny(['createdAt']) || data.createdAt is string)
        && (!data.keys().hasAny(['deadline']) || (data.deadline is string && data.deadline.size() == 10))
        && (!data.keys().hasAny(['isGoal']) || data.isGoal is bool);
    }

    // Users Collection Paths
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.userId == resource.data.userId;
      allow delete: if false;

      // Tasks Subcollection Paths
      match /tasks/{taskId} {
        allow get, list: if isOwner(userId);
        
        allow create: if isOwner(userId) 
          && isValidId(taskId)
          && isValidTask(request.resource.data);
          
        allow update: if isOwner(userId)
          && isValidId(taskId)
          && isValidTask(request.resource.data);
          
        allow delete: if isOwner(userId) && isValidId(taskId);
      }
    }
  }
}
