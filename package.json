{
  "name": "planflow",
  "private": true,
  "version": "1.0.0",
  "description": "Planflow daily task and calendar tracker",
  "author": "Planflow Team",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "build:win": "npm run generate:icons && npm run build && electron-builder --win portable",
    "build:android": "npm run generate:icons && npm run build && npx cap sync android && cd android && gradlew.bat assembleDebug",
    "android:sha": "node scripts/print-android-sha.mjs",
    "build:all": "npm run build:win && npm run build:android",
    "cap:sync": "npm run build && npx cap sync android",
    "generate:icons": "node scripts/generate-icons.mjs"
  },
  "build": {
    "appId": "com.planflow.dailytracker",
    "productName": "Planflow",
    "icon": "build/icon.ico",
    "directories": {
      "output": "../planflow-release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "build/icon.ico"
    ],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Planflow-${version}-Windows.exe"
    }
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^7.5.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.6.0",
    "@capacitor/local-notifications": "^7.0.6",
    "@capacitor/status-bar": "^7.0.6",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.14.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@capacitor/android": "^7.4.2",
    "@capacitor/cli": "^7.4.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.1.14",
    "to-ico": "^1.1.5",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
